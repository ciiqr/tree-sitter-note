          "type": "PATTERN",
          "value": "[ \\t]*"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "SYMBOL",
              "name": "section"
            },
            {
              "type": "SYMBOL",
              "name": "done"
            },
            {
              "type": "SYMBOL",
              "name": "todo"

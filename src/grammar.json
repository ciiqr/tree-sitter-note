{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "note",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_line"
      }
    },
    "_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[ \\t]*"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "SYMBOL",
              "name": "section"
            },
            {
              "type": "SYMBOL",
              "name": "done"
            },
            {
              "type": "SYMBOL",
              "name": "todo"
            },
            {
              "type": "SYMBOL",
              "name": "question"
            },
            {
              "type": "SYMBOL",
              "name": "partial"
            },
            {
              "type": "SYMBOL",
              "name": "important"
            },
            {
              "type": "SYMBOL",
              "name": "urgent"
            },
            {
              "type": "SYMBOL",
              "name": "plain"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "\n"
        }
      ]
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "#"
            },
            {
              "type": "PATTERN",
              "value": "[^\\n]*"
            }
          ]
        }
      }
    },
    "section": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "% "
            },
            {
              "type": "PATTERN",
              "value": "[^\\n]*"
            }
          ]
        }
      }
    },
    "done": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "x "
            },
            {
              "type": "PATTERN",
              "value": "[^\\n]*"
            }
          ]
        }
      }
    },
    "todo": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "- "
            },
            {
              "type": "PATTERN",
              "value": "[^\\n]*"
            }
          ]
        }
      }
    },
    "question": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "? "
            },
            {
              "type": "PATTERN",
              "value": "[^\\n]*"
            }
          ]
        }
      }
    },
    "partial": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "~ "
            },
            {
              "type": "PATTERN",
              "value": "[^\\n]*"
            }
          ]
        }
      }
    },
    "important": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "! "
            },
            {
              "type": "PATTERN",
              "value": "[^\\n]*"
            }
          ]
        }
      }
    },
    "urgent": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 3,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "!! "
            },
            {
              "type": "PATTERN",
              "value": "[^\\n]*"
            }
          ]
        }
      }
    },
    "plain": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "[^\\n]+"
        }
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}
            {
              "type": "SYMBOL",
              "name": "question"
            },
            {
              "type": "SYMBOL",
              "name": "partial"
            },
            {
              "type": "SYMBOL",
              "name": "important"
            },
            {
              "type": "SYMBOL",
              "name": "urgent"
            },
            {
              "type": "SYMBOL",
              "name": "plain"
            }
          ]
